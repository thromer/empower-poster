{
  "name": "extension",
  "private": true,
  "description": "Browser extension that posts Empower data to a user-provided endpoint",
  "version": "0.2.4",
  "author": "Ted Romer <tromer@gmail.com>",
  "license": "MIT",
  "keywords": [
    "finance"
  ],
  "homepage": "https://github.com/righteffort/empower-poster#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/righteffort/empower-poster.git",
    "directory": "node/fidelity-helper"
  },
  "bugs": {
    "url": "https://github.com/righteffort/empower-poster/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "compile": "yarn lint && tsc",
    "dev": "vite",
    "build": "yarn compile && vite build",
    "dist": "rm -f dist.zip && yarn build && cd dist && zip -r ../dist.zip *",
    "cli": "tsc -p tsconfig-cli.json && node dist-cli/cli/cli.js",
    "clean": "rm -rf dist dist-cli",
    "lint": "eslint {src,tests}/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "prettier": "prettier {src,tests}/**/*.{js,ts} --check",
    "prettier:fix": "prettier {src,tests}/**/*.{js,ts} --write",
    "test": "yarn vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/node": "^25.0.3",
    "@types/webextension-polyfill": "^0.10.0",
    "eslint": "^9.35.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0",
    "vite": "^5.0.0",
    "vite-plugin-web-extension": "^4.0.0",
    "vitest": "^4.0.16",
    "webextension-polyfill": "^0.10.0"
  }
}
